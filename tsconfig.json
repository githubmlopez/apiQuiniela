{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./src",
    /* Configuración de Alias */
    "paths": {
      "@core/*": ["./src/*"],
      "@config/*": ["./src/api/Configuracion/*"],
      "@middle/*": ["./src/api/Middle/*"],
      "@modelos/*": ["./src/api/Modelos/*"],
      "@interfaces/*": ["./src/api/Modelos/Interface/*"],
      "@router/*": ["./src/api/Router/*"],
      "@util/*": ["./src/api/Util/*"],
      "@modelos/comun/*": ["./src/api/Modelos/Modelo/COMUN/index.js"],
      "@modelos/quiniela/*": ["./src/api/Modelos/Modelo/NFLQUIN/index.js"],
      "@modelos/condom/*": ["./src/api/Modelos/Modelo/CONDOM/index.js"],

    },
    "typeRoots": [
      "./node_modules/@types",
      "./src/types" 
    ]
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist"
  ]
}